{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "automerge": true,
  "automergeType": "branch",
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },
  "commitMessagePrefix": "chore",
  "packageRules": [
    {
      "matchUpdateTypes": [
        "patch"
      ],
      "automerge": true,
      "labels": [
        "dependencies",
        "patch"
      ]
    },
    {
      "matchUpdateTypes": [
        "minor"
      ],
      "automerge": true,
      "labels": [
        "dependencies",
        "minor"
      ]
    },
    {
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false,
      "labels": [
        "dependencies",
        "manual"
      ]
    },
    {
      "matchDepTypes": [
        "devDependencies"
      ],
      "matchPackageNames": [
        "@types/*",
        "eslint",
        "typescript"
      ],
      "automerge": true,
      "labels": [
        "devDependencies",
        "auto-merge"
      ]
    },
    {
      "matchPackageNames": [
        "vitest"
      ],
      "matchUpdateTypes": [
        "patch",
        "minor"
      ],
      "automerge": true,
      "labels": [
        "dependencies",
        "vitest"
      ]
    },
    {
      "matchPackageNames": [
        "next",
        "react",
        "react-dom"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false,
      "labels": [
        "dependencies",
        "nextjs",
        "react",
        "manual"
      ]
    },
    {
      "matchPackagePatterns": [
        "^@base-ui/.*"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false,
      "labels": [
        "dependencies",
        "base-ui",
        "manual"
      ]
    },
    {
      "matchUpdateTypes": [
        "major"
      ],
      "commitMessagePrefix": "feat(deps-major):",
      "commitMessageAction": "Update {{packageName}}",
      "labels": [
        "dependencies",
        "major"
      ]
    },
    {
      "matchUpdateTypes": [
        "fix",
        "patch"
      ],
      "commitMessagePrefix": "fix(deps-patch):",
      "commitMessageAction": "Update {{packageName}}",
      "labels": [
        "dependencies",
        "fix-patch"
      ]
    },
    {
      "matchPackagePatterns": [
        ".*"
      ],
      "commitMessagePrefix": "chore(deps):",
      "commitMessageAction": "Update {{packageName}}"
    },
    {
      "description": "Pin scipy <1.16 — pod runs Python 3.10, scipy 1.16+ requires 3.11",
      "matchPackageNames": [
        "scipy"
      ],
      "allowedVersions": "<1.16"
    },
    {
      "description": "Pin numpy <2.3 — keep compatible with scipy 1.15.x on Python 3.10",
      "matchPackageNames": [
        "numpy"
      ],
      "allowedVersions": "<2.3"
    }
  ]
}