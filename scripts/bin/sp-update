#!/bin/bash
set -euo pipefail

# Use a fixed root command path. This keeps Pod 3's Volta shims out and makes
# sbin-only tools such as iptables and visudo available under systemd/sudo.
export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

# Serialize full installs, updates, and UI firewall toggles. The installer has
# historically used this path, so sharing it also protects mixed-version
# transitions while a pod is being upgraded.
MAINTENANCE_LOCK="/var/run/sleepypod-install.lock"

# Privileged firewall dispatch for the unprivileged web service. Keep this
# before every updater side effect: the installed sudoers rule already permits
# the root-owned sp-update binary, which lets the first OTA bootstrap the new
# sp-internet-control helper without widening that rule.
if [ "${1:-}" = "--internet-access" ]; then
  if [ "$#" -ne 2 ] || { [ "$2" != "block" ] && [ "$2" != "unblock" ]; }; then
    echo "Usage: sp-update --internet-access {block|unblock}" >&2
    exit 2
  fi

  exec 200>"$MAINTENANCE_LOCK"
  if ! flock -n 200; then
    echo "Error: an installation or update is already running" >&2
    exit 1
  fi

  INTERNET_CONTROL_HELPER="/usr/local/bin/sp-internet-control"
  HELPER_META="$(stat -c '%u:%a' "$INTERNET_CONTROL_HELPER" 2>/dev/null || true)"
  if [ ! -f "$INTERNET_CONTROL_HELPER" ] || [ ! -x "$INTERNET_CONTROL_HELPER" ] \
    || [[ ! "$HELPER_META" =~ ^0:[0-7]*[0145][0145]$ ]]; then
    echo "Error: firewall helper is missing or has unsafe ownership/mode" >&2
    exit 1
  fi
  exec "$INTERNET_CONTROL_HELPER" "$2"
fi

exec 200>"$MAINTENANCE_LOCK"
if ! flock -n 200; then
  echo "Error: another installation or update is already running" >&2
  exit 1
fi

# sp-update — self-update sleepypod-core from GitHub via curl+tarball
#
# Usage:
#   sp-update              # update to latest main
#   sp-update feat/alarms  # update to a specific branch
#
# Handles iptables toggle automatically (opens WAN, downloads, closes WAN).
# No git required — uses GitHub's tarball API.

INSTALL_DIR="/home/dac/sleepypod-core"
# DATA_DIR pointer is written by scripts/install (storage-aware picker).
# Legacy fallback keeps installs without the pointer file working.
if [ -r /etc/sleepypod/data-dir ] && [ -s /etc/sleepypod/data-dir ]; then
  DATA_DIR="$(cat /etc/sleepypod/data-dir)"
else
  DATA_DIR="/persistent/sleepypod-data"
fi
GITHUB_REPO="${SLEEPYPOD_GITHUB_REPO:-sleepypod/core}"
BRANCH="${1:-main}"

echo "=== SleepyPod Update ==="
echo "Branch: $BRANCH"
echo "Repo:   $GITHUB_REPO"
echo ""

PRIVACY_HELPERS="/usr/local/bin/sp-network-privacy"
FIREWALL_HELPER=/usr/local/bin/sp-internet-control
if [ ! -r "$PRIVACY_HELPERS" ] || [ ! -x "$FIREWALL_HELPER" ]; then
  echo "Error: $PRIVACY_HELPERS is missing." >&2
  echo "       Run the full installer once to migrate this legacy installation." >&2
  exit 1
fi
# shellcheck source=scripts/bin/sp-network-privacy
source "$PRIVACY_HELPERS"

PRE_UPDATE_FIREWALL_MODE=""

# This is mandatory even when WAN is already open. It protects the two stock
# cloud clients during updates and refreshes stale managed blocks atomically.
if ! ensure_telemetry_hosts_block; then
  echo "Error: refusing to update without the Eight Sleep hosts block" >&2
  exit 1
fi

# Cleanup state is semantic, not tied to whether a particular unblock command
# happened. A blocked installation must recover Local Only even if failure
# occurs during final persistence rather than during the download window.
ROLLBACK_READY=false
SERVICE_WAS_ACTIVE=false
SERVICE_QUIESCED=false
SERVICE_START_ATTEMPTED=false
FIREWALL_RECOVERY_REQUIRED=false

# Invoked by the EXIT trap below.
# shellcheck disable=SC2329
cleanup() {
  local exit_code=$?
  local firewall_safe=true rollback_ok=true
  trap - EXIT
  set +e

  if [ "$exit_code" -ne 0 ]; then
    if { [ "$SERVICE_QUIESCED" = true ] || [ "$SERVICE_START_ATTEMPTED" = true ]; } \
      && systemctl is-active --quiet sleepypod.service 2>/dev/null; then
      systemctl stop sleepypod.service 2>/dev/null || true
      if systemctl is-active --quiet sleepypod.service 2>/dev/null; then
        echo "ERROR: failed to stop sleepypod.service during rollback" >&2
        rollback_ok=false
      fi
    fi

    if [ "$FIREWALL_RECOVERY_REQUIRED" = true ]; then
      echo "Restoring Local Only firewall policy..." >&2
      if ! "$FIREWALL_HELPER" block; then
        echo "Canonical firewall rebuild failed; trying the persisted policy..." >&2
        /usr/local/bin/sp-firewall-restore || firewall_safe=false
      fi
    fi
    if [ -n "$PRE_UPDATE_FIREWALL_MODE" ]; then
      network_privacy_state_matches "$PRE_UPDATE_FIREWALL_MODE" || firewall_safe=false
    else
      # No firewall mutation happens before mode capture. If capture itself
      # fails, only require the hosts defense before restoring the old app.
      network_privacy_hosts_block_current "$(network_privacy_hosts_file)" || firewall_safe=false
    fi

    if [ "$ROLLBACK_READY" = true ]; then
      echo "Update failed, rolling back..." >&2
      if [ -d "$BACKUP_DIR" ]; then
        if ! find "$INSTALL_DIR" -mindepth 1 -maxdepth 1 \
          ! -name 'node_modules' \
          ! -name '.env' \
          -exec rm -rf {} + \
          || ! cp -r "$BACKUP_DIR/." "$INSTALL_DIR/"; then
          echo "ERROR: failed to restore the previous application code" >&2
          rollback_ok=false
        else
          # sp-* tools intentionally roll forward: they are installed outside
          # the application tree and contain the updater/repair path itself.
          echo "Previous code restored."
        fi
      else
        echo "ERROR: update rollback directory is missing" >&2
        rollback_ok=false
      fi
      if [ -n "${DB_BACKUP:-}" ] && [ -f "$DB_BACKUP" ]; then
        if ! cp "$DB_BACKUP" "$DATA_DIR/sleepypod.db"; then
          echo "ERROR: failed to restore the database" >&2
          rollback_ok=false
        fi
        # Restore the WAL/SHM sidecars to a state consistent with the .db
        # backup. A missing backup sidecar means the live sidecar must be
        # removed, or SQLite could replay post-rollback transactions.
        WAL_BAK="$DATA_DIR/sleepypod.db-wal.bak.${BACKUP_TS:-}"
        SHM_BAK="$DATA_DIR/sleepypod.db-shm.bak.${BACKUP_TS:-}"
        if [ -f "$WAL_BAK" ]; then
          cp "$WAL_BAK" "$DATA_DIR/sleepypod.db-wal" || rollback_ok=false
        else
          rm -f "$DATA_DIR/sleepypod.db-wal"
        fi
        if [ -f "$SHM_BAK" ]; then
          cp "$SHM_BAK" "$DATA_DIR/sleepypod.db-shm" || rollback_ok=false
        else
          rm -f "$DATA_DIR/sleepypod.db-shm"
        fi
        chown root:sleepypod "$DATA_DIR/sleepypod.db" 2>/dev/null || true
        chmod 0660 "$DATA_DIR/sleepypod.db" 2>/dev/null || true
        [ -f "$DATA_DIR/sleepypod.db-wal" ] && chown root:sleepypod "$DATA_DIR/sleepypod.db-wal" 2>/dev/null || true
        [ -f "$DATA_DIR/sleepypod.db-wal" ] && chmod 0660 "$DATA_DIR/sleepypod.db-wal" 2>/dev/null || true
        [ -f "$DATA_DIR/sleepypod.db-shm" ] && chown root:sleepypod "$DATA_DIR/sleepypod.db-shm" 2>/dev/null || true
        [ -f "$DATA_DIR/sleepypod.db-shm" ] && chmod 0660 "$DATA_DIR/sleepypod.db-shm" 2>/dev/null || true
        echo "Database restored from $DB_BACKUP."
      fi
    fi

    if [ "$SERVICE_WAS_ACTIVE" = true ] && [ "$SERVICE_QUIESCED" = true ]; then
      if [ "$firewall_safe" = true ] && [ "$rollback_ok" = true ]; then
        systemctl start sleepypod.service 2>/dev/null || true
      else
        echo "ERROR: rollback or firewall verification failed; leaving sleepypod.service stopped" >&2
      fi
    fi
  fi
  exit "$exit_code"
}
trap cleanup EXIT

# Pre-flight: disk space
DISK_AVAIL=$(df -m "$INSTALL_DIR" | awk 'NR==2{print $4}')
if [ "$DISK_AVAIL" -lt 300 ]; then
  echo "Error: Need 300MB free, only ${DISK_AVAIL}MB available" >&2
  exit 1
fi

# Stop the web service before opening WAN so a concurrent UI toggle cannot race
# the updater and have its newer choice overwritten by final convergence.
if systemctl is-active --quiet sleepypod.service 2>/dev/null; then
  SERVICE_WAS_ACTIVE=true
fi
SERVICE_QUIESCED=true
if ! systemctl stop sleepypod.service; then
  echo "Error: failed to stop sleepypod.service" >&2
  exit 1
fi
if systemctl is-active --quiet sleepypod.service 2>/dev/null; then
  echo "Error: sleepypod.service did not stop" >&2
  exit 1
fi

# Wait for an already-running UI toggle to finish, then capture the user's
# semantic mode while the API is quiesced. Release this lock before invoking
# sp-internet-control because that helper acquires the same lock itself.
FIREWALL_LOCK="/run/lock/sleepypod-internet-control.lock"
mkdir -p "$(dirname "$FIREWALL_LOCK")"
exec 8>"$FIREWALL_LOCK"
if ! flock -w 15 8; then
  echo "Error: another firewall transition is still running" >&2
  exit 1
fi
if ! PRE_UPDATE_FIREWALL_MODE="$(detect_firewall_mode)"; then
  flock -u 8
  exec 8>&-
  echo "Error: refusing to update without a trustworthy firewall mode" >&2
  exit 1
fi
flock -u 8
exec 8>&-

# Open WAN only when the captured mode was Local Only.
if [ "$PRE_UPDATE_FIREWALL_MODE" = block ]; then
  FIREWALL_RECOVERY_REQUIRED=true
  "$FIREWALL_HELPER" temporary-unblock
fi

# Check connectivity
if ! curl -sf --max-time 10 https://github.com > /dev/null 2>&1; then
  echo "Error: Cannot reach GitHub. Check network." >&2
  exit 1
fi

# Backup current code for rollback (everything except node_modules)
BACKUP_DIR="/tmp/sleepypod-rollback"
rm -rf "$BACKUP_DIR"
mkdir -p "$BACKUP_DIR"
tar cf - -C "$INSTALL_DIR" --exclude='node_modules' . 2>/dev/null | tar xf - -C "$BACKUP_DIR" || true

# Backup database (service is stopped, so WAL/SHM are consistent)
# Timestamped name so two rapid updates don't clobber the previous backup.
# Matches scripts/install's naming; sp-maintenance prunes to 3 most recent.
BACKUP_TS=$(date +%s)
DB_BACKUP="$DATA_DIR/sleepypod.db.bak.$BACKUP_TS"
if [ -f "$DATA_DIR/sleepypod.db" ]; then
  cp "$DATA_DIR/sleepypod.db" "$DB_BACKUP"
  [ -f "$DATA_DIR/sleepypod.db-wal" ] && cp "$DATA_DIR/sleepypod.db-wal" "$DATA_DIR/sleepypod.db-wal.bak.$BACKUP_TS"
  [ -f "$DATA_DIR/sleepypod.db-shm" ] && cp "$DATA_DIR/sleepypod.db-shm" "$DATA_DIR/sleepypod.db-shm.bak.$BACKUP_TS"
  echo "Database backed up to $DB_BACKUP."
fi

# Download code — try CI release first (includes pre-built .next), fall back to source tarball
WORK_DIR=$(mktemp -d)
HAS_BUILD=false

# Resolve the release endpoint. Mirrors scripts/install so OTA updates use
# the same CI-built tarballs as fresh installs:
#   main / latest      → releases/latest (semantic-release vX.Y.Z asset)
#   dev                → releases/tags/dev-latest      (built by dev-release.yml)
#   <other branch>     → releases/tags/<slug>-latest   (built by branch-release.yml)
# Slugging matches branch-release.yml: `feat/foo` → `feat-foo-latest`.
if [ "$BRANCH" = "main" ] || [ "$BRANCH" = "latest" ]; then
  RELEASE_API="https://api.github.com/repos/${GITHUB_REPO}/releases/latest"
  echo "Checking for CI release (latest stable)..."
elif [ "$BRANCH" = "dev" ]; then
  RELEASE_API="https://api.github.com/repos/${GITHUB_REPO}/releases/tags/dev-latest"
  echo "Checking for CI release (tag: dev-latest)..."
else
  RELEASE_TAG="${BRANCH//\//-}-latest"
  RELEASE_API="https://api.github.com/repos/${GITHUB_REPO}/releases/tags/${RELEASE_TAG}"
  echo "Checking for CI release (tag: $RELEASE_TAG)..."
fi
RELEASE_URL=$(curl -sf "$RELEASE_API" \
  | grep -om1 '"browser_download_url": *"[^"]*sleepypod-core\.tar\.gz"' \
  | grep -o 'https://[^"]*' || true)

if [ -n "$RELEASE_URL" ]; then
  echo "Downloading CI release..."
  if curl -fSL "$RELEASE_URL" | tar xz -C "$WORK_DIR"; then
    HAS_BUILD=true
    echo "CI release downloaded (pre-built)."
  else
    # CI download failed mid-stream (e.g. curl truncation). Partial
    # files would otherwise contaminate WORK_DIR — the source-tarball
    # fallback below extracts into the same dir, and `ls "$WORK_DIR"
    # | head -1` would then pick up stale CI-release contents instead
    # of the freshly-extracted source subdir. Mirrors scripts/install.
    find "$WORK_DIR" -mindepth 1 -delete 2>/dev/null || true
  fi
fi

if [ "$HAS_BUILD" = false ]; then
  # A failed CI-release download can leave partial extraction in WORK_DIR;
  # drop and recreate so the source-tarball structure check is reliable.
  rm -rf "$WORK_DIR"
  WORK_DIR=$(mktemp -d)
  # Fall back to source tarball (no .next — would need build on pod)
  # "latest" is not a real branch — use main for the source tarball
  SOURCE_BRANCH="$BRANCH"
  [ "$SOURCE_BRANCH" = "latest" ] && SOURCE_BRANCH="main"
  echo "Downloading $SOURCE_BRANCH from GitHub..."
  TARBALL_URL="https://github.com/${GITHUB_REPO}/archive/refs/heads/${SOURCE_BRANCH}.tar.gz"
  if ! curl -fSL "$TARBALL_URL" | tar xz -C "$WORK_DIR"; then
    echo "Error: Failed to download branch '$BRANCH'" >&2
    exit 1
  fi
  # Source tarball extracts to a subdirectory (e.g., core-main/)
  SUBDIR=$(ls "$WORK_DIR" | head -1)
  if [ -z "$SUBDIR" ] || [ ! -d "$WORK_DIR/$SUBDIR" ]; then
    echo "Error: Unexpected tarball structure in $WORK_DIR" >&2
    exit 1
  fi
  # Move contents up so WORK_DIR is the root
  mv "$WORK_DIR/$SUBDIR"/* "$WORK_DIR/$SUBDIR"/.[!.]* "$WORK_DIR/" 2>/dev/null || true
  rmdir "$WORK_DIR/$SUBDIR" 2>/dev/null || true
fi

# Clean old files (preserve node_modules, .env)
find "$INSTALL_DIR" -mindepth 1 -maxdepth 1 \
  ! -name 'node_modules' \
  ! -name '.env' \
  -exec rm -rf {} +
ROLLBACK_READY=true

# Move new code into place
cp -r "$WORK_DIR/." "$INSTALL_DIR/"
rm -rf "$WORK_DIR"
echo "Source updated."

cd "$INSTALL_DIR"

# Move node_modules off rootfs onto /persistent before pnpm runs.
# Migrates existing rootfs node_modules on the first sp-update after
# the relocation feature lands; subsequent runs are no-ops.
if [ -f "$INSTALL_DIR/scripts/lib/relocation-helpers" ]; then
  source "$INSTALL_DIR/scripts/lib/relocation-helpers"
  ensure_persistent_node_modules "$INSTALL_DIR"
fi

# Install production dependencies
pnpm install --frozen-lockfile --prod

# Build only if no pre-built .next exists
if [ ! -d "$INSTALL_DIR/.next" ]; then
  echo "No pre-built .next found, building..."
  # CI=true so pnpm doesn't prompt for TTY confirmation when prod-only
  # node_modules need to be replaced with the full dev set.
  CI=true pnpm install --frozen-lockfile
  SP_BRANCH="$BRANCH" pnpm build
else
  # Regenerate .git-info with the correct branch for pre-built releases
  SP_BRANCH="$BRANCH" node scripts/generate-git-info.mjs 2>/dev/null || true
fi

# Validate the build actually produced a startable .next bundle. next start
# refuses to boot without BUILD_ID and silently crashloops via systemd
# Restart=on-failure, so without this check sp-update would print "Update
# complete!" while the service is dying every 10 seconds.
if [ ! -f "$INSTALL_DIR/.next/BUILD_ID" ]; then
  echo "Error: build did not produce $INSTALL_DIR/.next/BUILD_ID — refusing to start service" >&2
  echo "Inspect the build output above; common causes: pnpm build script swallowed an error, OOM/SIGTERM during turbopack, or pre-built tarball missing the file." >&2
  exit 1
fi

# Sync biometrics modules
if [ -d "$INSTALL_DIR/modules" ]; then
  MODULES_DEST="/opt/sleepypod/modules"
  mkdir -p "$MODULES_DEST"
  # Match the install script's shared uv cache + Python install dir so
  # User=dac modules can execute the managed Python (otherwise it lives
  # under root's home at 0700 and the .venv symlink fails with 203/EXEC).
  export UV_PYTHON_INSTALL_DIR="/opt/sleepypod/python"
  export UV_CACHE_DIR="/opt/sleepypod/uv-cache"
  mkdir -p "$UV_PYTHON_INSTALL_DIR" "$UV_CACHE_DIR"
  chmod 0755 /opt/sleepypod "$UV_PYTHON_INSTALL_DIR" "$UV_CACHE_DIR" 2>/dev/null || true
  # uv is required to (re)build each module's .venv. The per-module sync
  # below wipes the existing .venv before rebuilding, so running it without
  # uv would leave previously-working biometrics modules dead (203/EXEC) on
  # a venv that can't be recreated. Install uv first (same source as the
  # full installer); if it still isn't available, skip the module sync
  # entirely and leave the running modules untouched rather than
  # half-upgrading into a broken state.
  if ! command -v uv &>/dev/null; then
    echo "uv not found — installing (required to rebuild biometrics module venvs)..."
    curl -LsSf https://astral.sh/uv/install.sh \
      | UV_INSTALL_DIR=/usr/local/bin INSTALLER_NO_MODIFY_PATH=1 sh || true
  fi
  # Probe the firmware's /usr/bin/python3 for stdlib integrity. Pod 3
  # firmware (debian variant) ships 3.9.9 with unittest, dataclasses,
  # and pyexpat stripped — version check passes, uv would happily bind
  # the venv to it, modules crash at startup. Mirror install_module()'s
  # behavior here so OTAs don't silently revert to the broken interpreter.
  # If capabilities is missing (transitional install), default to "true"
  # to keep the previous behavior (no managed-Python forcing).
  if [ -f "$INSTALL_DIR/scripts/pod/capabilities" ]; then
    source "$INSTALL_DIR/scripts/pod/capabilities"
  fi
  if ! command -v uv &>/dev/null; then
    echo "ERROR: uv unavailable — skipping biometrics module sync." >&2
    echo "       Existing modules keep their current venvs and units (left running)," >&2
    echo "       but RAW/biometrics fixes in this update are NOT deployed." >&2
    echo "       Re-run the full installer once uv can be installed." >&2
  else
    if [ -d "$INSTALL_DIR/modules/common" ]; then
      mkdir -p "$MODULES_DEST/common"
      cp -r "$INSTALL_DIR/modules/common/." "$MODULES_DEST/common/"
    fi
    for mod in piezo-processor sleep-detector environment-monitor calibrator cover-buttons; do
      if [ -d "$INSTALL_DIR/modules/$mod" ]; then
        mkdir -p "$MODULES_DEST/$mod"
        cp -r "$INSTALL_DIR/modules/$mod/." "$MODULES_DEST/$mod/"
        rm -rf "$MODULES_DEST/$mod/venv"
        # Also wipe .venv so OTAs pick up the shared UV_PYTHON_INSTALL_DIR
        # set above — otherwise a pre-v1.7.3 venv's bin/python symlink keeps
        # pointing at /home/root/.local/share/uv/… and User=dac modules fail
        # to exec. uv's content-addressable cache means this is a cheap
        # re-link, not a full re-download.
        rm -rf "$MODULES_DEST/$mod/.venv"
        _uv_sync_args=(--frozen)
        if [ "${SYSTEM_PYTHON_STDLIB_INTACT:-true}" = "false" ]; then
          _uv_sync_args+=(--python-preference only-managed)
        fi
        (cd "$MODULES_DEST/$mod" && uv sync "${_uv_sync_args[@]}") \
          || echo "Warning: uv sync failed for module $mod"
        unset _uv_sync_args
        chmod -R o+rX "$MODULES_DEST/$mod/.venv" 2>/dev/null || true
        svc="sleepypod-$mod.service"
        if [ -f "$MODULES_DEST/$mod/$svc" ]; then
          # Substitute the chosen $DATA_DIR for the baked-in
          # /persistent/sleepypod-data — the unit's ReadWritePaths= and
          # DATABASE_URL=/CALIBRATION_TRIGGER_PATH= reference it, and on
          # installs where the picker chose /sleepypod-data the hardcoded
          # path doesn't exist → systemd "Failed to set up mount
          # namespacing". Mirrors install_module() in scripts/install
          # (boundary match + replacement escapes) so OTAs don't stomp
          # the substituted unit with a vanilla copy. Keep the two
          # sed expressions in sync.
          _data_dir_sed=${DATA_DIR//\\/\\\\}
          _data_dir_sed=${_data_dir_sed//&/\\&}
          _data_dir_sed=${_data_dir_sed//|/\\|}
          sed -E "s|/persistent/sleepypod-data([/\"[:space:]])|${_data_dir_sed}\\1|g; s|/persistent/sleepypod-data\$|${_data_dir_sed}|g" \
            "$MODULES_DEST/$mod/$svc" > "/etc/systemd/system/$svc"
          chmod 0644 "/etc/systemd/system/$svc"
          unset _data_dir_sed
          systemctl daemon-reload
          systemctl enable "$svc" 2>/dev/null || true
          systemctl restart "$svc" 2>/dev/null || true
        fi
      fi
    done
  fi
fi

# Biometrics archiver — tmpfs RAW writes + frank.sh cd patch. Module
# unit files set RAW_DATA_DIR=/persistent/biometrics, so without this the
# modules tail a directory that doesn't exist and biometrics silently
# stop populating. Pre-#576, this only ran from scripts/install, so any
# pod that upgraded via sp-update past v2.0.0 hit the regression.
if [ -f "$INSTALL_DIR/scripts/lib/biometrics-archiver-helpers" ]; then
  source "$INSTALL_DIR/scripts/lib/biometrics-archiver-helpers"
  install_biometrics_archiver
fi

# Self-heal the xtables lockfile env for pods installed before this fix.
# Without it, setInternetAccess crashes the first time a user toggles WAN
# ("can't open lock file /run/xtables.lock: Permission denied"). The main
# unit gets this Environment= line in fresh installs; for OTA upgrades we
# drop it in so we don't have to rewrite the entire service unit.
XTABLES_DROPIN=/etc/systemd/system/sleepypod.service.d/iptables-lockfile.conf
if [ ! -f "$XTABLES_DROPIN" ]; then
  mkdir -p "$(dirname "$XTABLES_DROPIN")"
  cat > "$XTABLES_DROPIN" << 'EOF'
[Service]
Environment="XTABLES_LOCKFILE=/run/dac/xtables.lock"
EOF
  systemctl daemon-reload
fi

# Order the Node sensor streamer after firmware NATS when that unit exists.
# This is deliberately ordering-only (no Wants=/Requires=): old-firmware pods
# do not ship nats-server.service and must continue starting normally. The
# streamer's own 60-second probe remains the race-safe runtime selector.
NATS_ORDERING_DROPIN=/etc/systemd/system/sleepypod.service.d/nats-ordering.conf
if [ ! -f "$NATS_ORDERING_DROPIN" ]; then
  mkdir -p "$(dirname "$NATS_ORDERING_DROPIN")"
  cat > "$NATS_ORDERING_DROPIN" << 'EOF'
[Unit]
After=nats-server.service
EOF
  systemctl daemon-reload
fi

# Install CLI tools from new source.
#
# Use `install` (atomic mkstemp + rename) instead of `cp` — sp-update is
# one of the sp-* tools being replaced here. `cp` truncates+writes into
# the same inode, so the running bash reads garbage from its own script
# after the overwrite ("line N: ): command not found" mid-run). `install`
# stages new bytes at a fresh inode and renames over the path, so the
# running process's open fd keeps pointing at the original content.
if [ -d "$INSTALL_DIR/scripts/bin" ]; then
  for tool in "$INSTALL_DIR/scripts/bin"/sp-*; do
    install -m 0755 "$tool" "/usr/local/bin/$(basename "$tool")"
  done
fi

# Re-source the downloaded version, then converge every privileged artifact.
# A blocked installation is rebuilt with the canonical v4/v6 policy; an open
# installation has its current rules persisted without flushing unrelated
# narrow rules. This replaces verbatim restoration of legacy/broken policies.
# shellcheck source=scripts/bin/sp-network-privacy
source /usr/local/bin/sp-network-privacy
ensure_telemetry_hosts_block
install_sleepypod_update_sudoers
# Ensure a failed transition with quarantined persistence also fails closed on
# reboot before attempting the final runtime/persisted convergence.
install_firewall_restore_service
converge_firewall_mode "$PRE_UPDATE_FIREWALL_MODE"
network_privacy_state_matches "$PRE_UPDATE_FIREWALL_MODE"

# Clear the recovery obligation immediately after the canonical runtime and
# boot policy verify. Marker failure must not undo the validated firewall.
FIREWALL_RECOVERY_REQUIRED=false
mark_network_privacy_migrated

echo "Starting service..."
SERVICE_START_ATTEMPTED=true
systemctl start sleepypod.service

sleep 5
if systemctl is-active --quiet sleepypod.service; then
  rm -rf "$BACKUP_DIR"
  echo "Update complete! Service is running."
  exit 0
fi

# If we get here, service didn't start.
# Cleanup trap handles rollback — just exit with failure.
exit 1
