#!/bin/bash
set -euo pipefail

usage() {
  cat << EOF
Usage: $(basename "$0") {block|unblock|hosts-block|hosts-unblock|status}

Control internet access for SleepyPod device.

Commands:
  block         - Block all internet access via iptables (keep local network only)
  unblock       - Restore full internet access via iptables
  hosts-block   - Null-route Eight Sleep telemetry domains in /etc/hosts
  hosts-unblock - Remove Eight Sleep null routes from /etc/hosts
  status        - Show current blocking status (iptables + hosts)

The pod uses two layers of outbound blocking:
  1. iptables: DROP all non-LAN outbound traffic (primary)
  2. /etc/hosts: null-route *.8slp.net domains (defense-in-depth)

Layer 2 prevents data exfiltration when iptables are temporarily
opened for sp-update or other maintenance.

Examples:
  sudo $(basename "$0") block          # iptables block
  sudo $(basename "$0") hosts-block    # add /etc/hosts null routes
  sudo $(basename "$0") hosts-unblock  # remove /etc/hosts null routes
  sudo $(basename "$0") status         # check both layers
EOF
  exit 1
}

# Check if running as root
if [ "$EUID" -ne 0 ]; then
  echo "Error: This script must be run as root" >&2
  exit 1
fi

# Check for command
if [ $# -ne 1 ]; then
  usage
fi

COMMAND="$1"

# ---------------------------------------------------------------------------
# Pod OS / iptables detection
# ---------------------------------------------------------------------------
# Pod 3/4 run Yocto (no apt, iptables at /sbin/iptables)
# Pod 5 runs Debian (has apt, iptables at /usr/sbin/iptables)
if [ -x /usr/bin/apt-get ]; then
  POD_OS="debian"
  IPTABLES="/usr/sbin/iptables"
  IP6TABLES="/usr/sbin/ip6tables"
else
  POD_OS="yocto"
  IPTABLES="/sbin/iptables"
  IP6TABLES="/sbin/ip6tables"
fi

# ---------------------------------------------------------------------------
# /etc/hosts management for Eight Sleep telemetry blocking
# ---------------------------------------------------------------------------

# Marker comments used to find our block in /etc/hosts
HOSTS_MARKER_BEGIN="# BEGIN sleepypod-telemetry-block"
HOSTS_MARKER_END="# END sleepypod-telemetry-block"

# Known Eight Sleep cloud domains
EIGHTSLEEP_DOMAINS=(
  "raw-api-upload.8slp.net"   # frankenfirmware raw sensor data upload
  "device-api-ws.8slp.net"    # Capybara WebSocket device API hub
  "api.8slp.net"              # general API
  "app-api.8slp.net"          # mobile app API
  "client-api.8slp.net"       # client API
)

hosts_is_blocked() {
  # Both markers must be present exactly once for a well-formed block
  local begin_count end_count
  begin_count=$(grep -Fc "$HOSTS_MARKER_BEGIN" /etc/hosts 2>/dev/null || true)
  end_count=$(grep -Fc "$HOSTS_MARKER_END" /etc/hosts 2>/dev/null || true)
  [ "$begin_count" -eq 1 ] && [ "$end_count" -eq 1 ]
}

hosts_markers_malformed() {
  local begin_count end_count
  begin_count=$(grep -Fc "$HOSTS_MARKER_BEGIN" /etc/hosts 2>/dev/null || true)
  end_count=$(grep -Fc "$HOSTS_MARKER_END" /etc/hosts 2>/dev/null || true)
  [ "$begin_count" -ne "$end_count" ]
}

add_hosts_block() {
  if hosts_is_blocked; then
    echo "Eight Sleep hosts block already present"
    return 0
  fi

  if hosts_markers_malformed; then
    echo "Warning: malformed hosts markers found, cleaning up first" >&2
    sed -i "/$HOSTS_MARKER_BEGIN/d;/$HOSTS_MARKER_END/d" /etc/hosts
  fi

  # Backup before modifying
  cp /etc/hosts /etc/hosts.bak.sleepypod

  {
    echo ""
    echo "$HOSTS_MARKER_BEGIN"
    echo "# Null-route Eight Sleep telemetry domains so the stock firmware"
    echo "# (frankenfirmware + Capybara) cannot phone home, even when"
    echo "# iptables are temporarily opened for sp-update."
    echo "# Managed by: scripts/internet-control hosts-block|hosts-unblock"
    for domain in "${EIGHTSLEEP_DOMAINS[@]}"; do
      echo "0.0.0.0 $domain"
    done
    echo "$HOSTS_MARKER_END"
  } >> /etc/hosts

  echo "Added ${#EIGHTSLEEP_DOMAINS[@]} Eight Sleep domains to /etc/hosts null route"
}

remove_hosts_block() {
  if hosts_markers_malformed; then
    echo "Error: malformed sleepypod hosts markers in /etc/hosts; refusing destructive edit" >&2
    echo "  Check /etc/hosts manually for mismatched BEGIN/END markers" >&2
    return 1
  fi

  if ! hosts_is_blocked; then
    echo "No Eight Sleep hosts block found"
    return 0
  fi

  # Backup before modifying
  cp /etc/hosts /etc/hosts.bak.sleepypod

  # Remove everything between (and including) the markers
  sed -i "/$HOSTS_MARKER_BEGIN/,/$HOSTS_MARKER_END/d" /etc/hosts

  # Clean up any trailing blank lines at end of file
  sed -i -e :a -e '/^\n*$/{$d;N;ba' -e '}' /etc/hosts

  echo "Removed Eight Sleep domains from /etc/hosts"
}

case "$COMMAND" in
  block)
    echo "========================================"
    echo "  Block WAN Internet Access"
    echo "========================================"
    echo ""

    # Get local network interface and subnet
    INTERFACE=$(ip route | awk '/default/ {print $5; exit}')
    if [ -z "$INTERFACE" ]; then
      echo "Error: Could not detect default network interface" >&2
      exit 1
    fi

    LOCAL_SUBNET=$(ip -4 addr show "$INTERFACE" | awk '/inet / {print $2; exit}')
    if [ -z "$LOCAL_SUBNET" ]; then
      echo "Error: Could not detect local subnet" >&2
      exit 1
    fi

    echo "Interface: $INTERFACE"
    echo "Local subnet: $LOCAL_SUBNET"
    echo ""

    # Install iptables + persistence on Debian; on Yocto it must be pre-installed
    if [ "$POD_OS" = "debian" ]; then
      if ! command -v "$IPTABLES" &>/dev/null || ! dpkg -l | grep -q iptables-persistent; then
        echo "Installing iptables..."
        apt-get update
        apt-get install -y iptables iptables-persistent
      fi
    else
      if ! command -v "$IPTABLES" &>/dev/null; then
        echo "Error: iptables not found at $IPTABLES. Cannot block WAN access." >&2
        exit 1
      fi
    fi

    # Create custom chain for SleepyPod rules (IPv4)
    "$IPTABLES" -N SLEEPYPOD-BLOCK 2>/dev/null || "$IPTABLES" -F SLEEPYPOD-BLOCK
    "$IPTABLES" -D OUTPUT -j SLEEPYPOD-BLOCK 2>/dev/null || true
    "$IPTABLES" -I OUTPUT -j SLEEPYPOD-BLOCK

    # Allow loopback
    "$IPTABLES" -A SLEEPYPOD-BLOCK -o lo -j ACCEPT

    # Allow established/related connections
    "$IPTABLES" -A SLEEPYPOD-BLOCK -m state --state ESTABLISHED,RELATED -j ACCEPT

    # Allow local network
    "$IPTABLES" -A SLEEPYPOD-BLOCK -d "$LOCAL_SUBNET" -j ACCEPT

    # Allow mDNS for local discovery
    "$IPTABLES" -A SLEEPYPOD-BLOCK -d 224.0.0.251/32 -p udp --dport 5353 -j ACCEPT

    # Block all other outbound traffic
    "$IPTABLES" -A SLEEPYPOD-BLOCK -j DROP

    # Save IPv4 rules
    mkdir -p /etc/iptables
    "${IPTABLES}-save" > /etc/iptables/rules.v4

    # Block IPv6 as well (prevents bypass)
    if command -v "$IP6TABLES" &>/dev/null; then
      echo "Configuring IPv6 rules..."

      "$IP6TABLES" -N SLEEPYPOD-BLOCK 2>/dev/null || "$IP6TABLES" -F SLEEPYPOD-BLOCK
      "$IP6TABLES" -D OUTPUT -j SLEEPYPOD-BLOCK 2>/dev/null || true
      "$IP6TABLES" -I OUTPUT -j SLEEPYPOD-BLOCK

      "$IP6TABLES" -A SLEEPYPOD-BLOCK -o lo -j ACCEPT
      "$IP6TABLES" -A SLEEPYPOD-BLOCK -m state --state ESTABLISHED,RELATED -j ACCEPT
      "$IP6TABLES" -A SLEEPYPOD-BLOCK -d fe80::/10 -j ACCEPT
      "$IP6TABLES" -A SLEEPYPOD-BLOCK -j DROP

      if command -v "${IP6TABLES}-save" &>/dev/null; then
        "${IP6TABLES}-save" > /etc/iptables/rules.v6
      fi
    fi

    # Also install /etc/hosts telemetry block as defense-in-depth
    echo "Installing /etc/hosts telemetry block..."
    add_hosts_block

    echo ""
    echo "✓ Internet access blocked!"
    echo "  Layer 1: iptables DROP on all non-LAN outbound"
    echo "  Layer 2: /etc/hosts null routes for *.8slp.net"
    echo "  Local network ($LOCAL_SUBNET) is still accessible"
    if command -v "$IP6TABLES" &>/dev/null; then
      echo "  IPv6 is also blocked"
    fi
    echo ""
    echo "To restore: sudo $(basename "$0") unblock"
    echo ""
    ;;

  unblock)
    echo "========================================"
    echo "  Restore WAN Internet Access"
    echo "========================================"
    echo ""

    # Remove custom chains (IPv4)
    if "$IPTABLES" -L SLEEPYPOD-BLOCK &>/dev/null; then
      echo "Removing IPv4 firewall rules..."
      "$IPTABLES" -D OUTPUT -j SLEEPYPOD-BLOCK 2>/dev/null || true
      "$IPTABLES" -F SLEEPYPOD-BLOCK
      "$IPTABLES" -X SLEEPYPOD-BLOCK
    fi

    "$IPTABLES" -P OUTPUT ACCEPT

    if command -v "${IPTABLES}-save" &>/dev/null; then
      mkdir -p /etc/iptables
      "${IPTABLES}-save" > /etc/iptables/rules.v4
    fi

    # Remove IPv6 rules
    if command -v "$IP6TABLES" &>/dev/null && "$IP6TABLES" -L SLEEPYPOD-BLOCK &>/dev/null; then
      echo "Removing IPv6 firewall rules..."
      "$IP6TABLES" -D OUTPUT -j SLEEPYPOD-BLOCK 2>/dev/null || true
      "$IP6TABLES" -F SLEEPYPOD-BLOCK
      "$IP6TABLES" -X SLEEPYPOD-BLOCK
      "$IP6TABLES" -P OUTPUT ACCEPT

      if command -v "${IP6TABLES}-save" &>/dev/null; then
        "${IP6TABLES}-save" > /etc/iptables/rules.v6
      fi
    fi

    echo ""
    echo "✓ Internet access restored!"
    echo "  Both IPv4 and IPv6 are now unblocked"
    echo ""
    ;;

  hosts-block)
    echo "========================================"
    echo "  Block Eight Sleep Telemetry (hosts)"
    echo "========================================"
    echo ""
    add_hosts_block
    echo ""
    echo "✓ Eight Sleep telemetry domains null-routed in /etc/hosts"
    echo "  frank (raw-api-upload.8slp.net) and Capybara (device-api-ws.8slp.net)"
    echo "  will resolve to 0.0.0.0 even when iptables are open"
    echo ""
    echo "To remove: sudo $(basename "$0") hosts-unblock"
    echo ""
    ;;

  hosts-unblock)
    echo "========================================"
    echo "  Remove Eight Sleep Telemetry Block"
    echo "========================================"
    echo ""
    remove_hosts_block
    echo ""
    echo "✓ /etc/hosts restored — Eight Sleep domains will resolve normally"
    echo "  Backup at /etc/hosts.bak.sleepypod"
    echo ""
    ;;

  status)
    echo "========================================"
    echo "  Network Blocking Status"
    echo "========================================"
    echo ""

    # Layer 1: iptables — check both OUTPUT and SLEEPYPOD-BLOCK chains
    if "$IPTABLES" -L SLEEPYPOD-BLOCK -n 2>/dev/null | grep -q "DROP"; then
      DROP_STATS=$("$IPTABLES" -L SLEEPYPOD-BLOCK -n -v 2>/dev/null | grep "DROP" | awk '{print $1 " packets, " $2}')
      echo "  Layer 1 (iptables):  ACTIVE — SLEEPYPOD-BLOCK chain ($DROP_STATS blocked)"
    elif "$IPTABLES" -L OUTPUT -n 2>/dev/null | grep -q "DROP"; then
      DROP_STATS=$("$IPTABLES" -L OUTPUT -n -v 2>/dev/null | grep "DROP" | awk '{print $1 " packets, " $2}')
      echo "  Layer 1 (iptables):  ACTIVE — DROP rule in OUTPUT ($DROP_STATS blocked)"
    else
      echo "  Layer 1 (iptables):  INACTIVE — no DROP rule found"
    fi

    # Layer 2: /etc/hosts
    if hosts_is_blocked; then
      DOMAIN_COUNT=$(sed -n "/$HOSTS_MARKER_BEGIN/,/$HOSTS_MARKER_END/p" /etc/hosts | grep "^0.0.0.0" | wc -l)
      echo "  Layer 2 (/etc/hosts): ACTIVE — $DOMAIN_COUNT domains null-routed"
    else
      echo "  Layer 2 (/etc/hosts): INACTIVE — no Eight Sleep null routes"
    fi

    echo ""

    # Show active Eight Sleep processes
    FRANK_PID=$(pgrep -f frankenfirmware 2>/dev/null || true)
    CAPY_PID=$(pgrep -f Eight.Capybara 2>/dev/null || true)
    if [ -n "$FRANK_PID" ] || [ -n "$CAPY_PID" ]; then
      echo "  Eight Sleep processes running:"
      [ -n "$FRANK_PID" ] && echo "    frank (PID $FRANK_PID) — sensor firmware + raw-api-upload.8slp.net"
      [ -n "$CAPY_PID" ] && echo "    Capybara (PID $CAPY_PID) — device-api-ws.8slp.net"
    else
      echo "  No Eight Sleep processes detected"
    fi
    echo ""
    ;;

  *)
    echo "Error: Unknown command '$COMMAND'" >&2
    echo ""
    usage
    ;;
esac
