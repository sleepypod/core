{
  "name": "@sleepypod/core",
  "type": "module",
  "private": true,
  "scripts": {
    "prebuild": "node scripts/generate-git-info.mjs && lingui compile",
    "build": "next build --no-turbopack",
    "dev": "next dev",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:biometrics:generate": "drizzle-kit generate --config=drizzle.biometrics.config.ts",
    "db:biometrics:migrate": "drizzle-kit migrate --config=drizzle.biometrics.config.ts",
    "db:biometrics:studio": "drizzle-kit studio --config=drizzle.biometrics.config.ts",
    "db:reset": "rm -f sleepypod.dev.db sleepypod.dev.db-shm sleepypod.dev.db-wal && pnpm db:migrate",
    "db:reset:all": "rm -f sleepypod.dev.db sleepypod.dev.db-shm sleepypod.dev.db-wal biometrics.dev.db biometrics.dev.db-shm biometrics.dev.db-wal && pnpm db:migrate && pnpm db:biometrics:migrate",
    "db:reset:biometrics": "rm -f biometrics.dev.db biometrics.dev.db-shm biometrics.dev.db-wal && pnpm db:biometrics:migrate",
    "db:reset:schedules": "sqlite3 sleepypod.dev.db \"BEGIN; DELETE FROM temperature_schedules; DELETE FROM power_schedules; DELETE FROM alarm_schedules; DELETE FROM run_once_sessions; COMMIT;\"",
    "db:reset:settings": "sqlite3 sleepypod.dev.db \"BEGIN; DELETE FROM device_settings; DELETE FROM side_settings; DELETE FROM tap_gestures; COMMIT;\"",
    "db:reset:state": "sqlite3 sleepypod.dev.db \"BEGIN; DELETE FROM device_state; DELETE FROM system_health; COMMIT;\"",
    "lingui:extract": "lingui extract --clean",
    "lint:fix": "eslint . --fix",
    "lint": "eslint .",
    "start": "next start",
    "test": "vitest",
    "tsc": "tsc --noEmit",
    "prepare": "git rev-parse --git-dir >/dev/null 2>&1 && git config core.hooksPath .githooks || true"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --fix",
    "*.css": "eslint --fix",
    "*.json": "eslint --fix"
  },
  "dependencies": {
    "@ajayche/trpc-panel": "^2.0.4",
    "@base-ui/react": "^1.2.0",
    "@formatjs/intl-localematcher": "^0.8.0",
    "@lingui/core": "^5.9.2",
    "@lingui/macro": "^5.9.2",
    "@lingui/react": "^5.9.2",
    "@tanstack/react-query": "^5.90.21",
    "@trpc/client": "^11.10.0",
    "@trpc/next": "^11.10.0",
    "@trpc/react-query": "^11.10.0",
    "@trpc/server": "^11.10.0",
    "@xyflow/react": "^12.10.1",
    "better-sqlite3": "^12.6.2",
    "binary-split": "^1.0.5",
    "bonjour-service": "^1.3.0",
    "cbor-x": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^1.0.0",
    "negotiator": "^1.0.0",
    "next": "^16.1.6",
    "node-schedule": "^2.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.0",
    "shadcn": "^4.0.0",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.5.0",
    "trpc-to-openapi": "^3.1.0",
    "tw-animate-css": "^1.4.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6",
    "zod-openapi": "^5.4.6"
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/css": "^1.0.0",
    "@eslint/js": "^9.39.3",
    "@eslint/json": "^1.0.0",
    "@lingui/babel-plugin-lingui-macro": "^5.9.2",
    "@lingui/cli": "^5.9.2",
    "@lingui/loader": "^5.9.2",
    "@lingui/swc-plugin": "^5.11.0",
    "@lingui/vite-plugin": "^5.9.2",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.9.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@tsconfig/next": "^2.0.5",
    "@types/better-sqlite3": "^7.6.13",
    "@types/binary-split": "^1.0.3",
    "@types/jsdom": "^28.0.0",
    "@types/negotiator": "^0.6.4",
    "@types/node": "^25.3.0",
    "@types/node-schedule": "^2.1.8",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "4.1.2",
    "conventional-changelog-conventionalcommits": "^9.1.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.3",
    "eslint-config-next": "^16.1.6",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.0.0",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.0",
    "lint-staged": "^16.4.0",
    "semantic-release": "^25.0.3",
    "tailwindcss": "4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "cbor-extract",
      "better-sqlite3",
      "esbuild",
      "sharp",
      "msw",
      "unrs-resolver"
    ]
  }
}