{
  "name": "sleep-detector",
  "version": "1.0.0",
  "description": "Sleep session boundaries and bed exit detection from capacitance presence sensors",
  "provides": [
    "sleep_records.enteredBedAt",
    "sleep_records.leftBedAt",
    "sleep_records.sleepDurationSeconds",
    "sleep_records.timesExitedBed",
    "sleep_records.presentIntervals",
    "sleep_records.notPresentIntervals",
    "movement.totalMovement"
  ],
  "writes": ["sleep_records", "movement"],
  "service": "sleepypod-sleep-detector.service",
  "language": "python",
  "minVersion": "1.0.0"
}
